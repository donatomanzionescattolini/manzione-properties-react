# ============================================================
# Manzione Properties – Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --------------------------------------------------
# Supabase (required for production)
# Find these in: Supabase Dashboard → Settings → API
# --------------------------------------------------
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# --------------------------------------------------
# Stripe (required for real payment processing)
# Find these in: Stripe Dashboard → Developers → API keys
# Use the PUBLISHABLE key here (never the secret key)
# --------------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# --------------------------------------------------
# App settings
# --------------------------------------------------
# Set to "true" ONLY in local development / staging to show demo login buttons
VITE_DEMO_MODE=false

# Public base URL of the app (used for redirect URLs in Supabase auth emails)
VITE_APP_URL=https://your-domain.com
