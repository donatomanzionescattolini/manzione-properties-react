# ============================================================
# Manzione Properties - Environment Variables
# Copy this file to .env and fill in your values
# See SETUP.md for complete setup instructions
# ============================================================

# ── Supabase (REQUIRED) ──────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Stripe (OPTIONAL - enables card payments in tenant portal) ─
# Get from: https://dashboard.stripe.com/apikeys
# Use pk_test_... for testing, pk_live_... for production
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ── Supabase Edge Function Secrets (set via Supabase CLI) ────
# These are NOT prefixed with VITE_ (not exposed to browser)
# Set them with: supabase secrets set KEY=value

# Stripe secret key (for create-payment-intent edge function)
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Resend API key (for email notifications)
# Get from: https://resend.com/api-keys
# RESEND_API_KEY=re_your_resend_api_key

# From email address (must be a verified domain in Resend)
# FROM_EMAIL=noreply@yourdomain.com
# FROM_NAME=Manzione Properties

# Your production site URL (for password reset redirects)
# SITE_URL=https://your-app.vercel.app
